@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>

    <script src="~/jquery/jquery.js"></script>
    <script src="~/jquery/jquery.min.js"></script>

    <script src="~/js/site.js"></script>

    <link href="~/lib/bootstrap/dist/css/bootstrap.css" rel="stylesheet" />
    <link href="~/lib/bootstrap/dist/css/datepicker.css" rel="stylesheet" />
    <script src="~/lib/bootstrap/dist/js/bootstrap-datepicker.js"></script>
    </head>
    <body>

        
        <div class="text-center">
            <h5 class="display-4"> </h5>
               <p>
                <a> Welcome : @ViewData["Message"]  </a>
            </p>
            <p>
                <a> EmployeeID : @ViewData["ID"]  </a>
            </p>
            <p>
                <a> Designation : @ViewData["desig"]  </a>
            </p>
        </div>

        <br />

    @using (Html.BeginForm("Index", "BIReportList", FormMethod.Post))
    {
        <div class="container text-center">
            <div class="row justify-content-md-center">
                <div class="col-auto">
                    <label for="Select Zone"> Select </label>

                    @Html.DropDownList("country", new SelectList(TempData["List"] as List<PrayasModels.BIReportsListModel>, "ReportName", "ReportName"), "Choose Report")
                   @*  @Html.DropDownList("country", ViewBag.country as List<SelectListItem>, "--Select Zone--", new { style = "width: 200px;" }) *@

                </div>

                <div class="col-auto">
                    <label for="Select Region"> Select </label>

                    @*@Html.DropDownList("SubReportName", new SelectList(string.Empty, "ReportID", "SubReportName"), "--Select Region--", new { style = "width:200px" })*@
                    @* @Html.DropDownList("State", new SelectList(string.Empty, "Value", "Text"), "--Select Region--", new { style = "width:200px" }) *@

                </div>
                <div class="col-auto">
                    @* <label for="dt1" class="visually-hidden">Start Date</label>
                <input type="text" class="form-control" id="dt1" placeholder="Date"> *@

                    <div class="col-auto">
                        <button type="Submit" class="btn btn-success mb-3" id="Index">Export to Excel</button>
                    </div>
                </div>
            </div>
        </div>

    }

        


    </body>



    </html>

